<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<?eclipse version="3.0"?><plugin>
                
    
    <!-- This is an example for providing an own category 
      <extension
         point="org.knime.workbench.repository.categories">
      <category
            description="Category containing my nodes"
            icon="icons/default.png"
            level-id="myNodes"
            name="My nodes"
            path="/"/>
   </extension>
   -->
                 
    
    <extension point="org.knime.workbench.repository.nodes">
                       
        
        <category description="Analytics" icon="icons/default.png" level-id="myNodes" name="My nodes" path="/"/>
                        
                
        
        <node category-path="/" description="Analytics" factory-class="cu.edu.cujae.daf.knime.DinosyNodeFactory" id="cu.edu.cujae.daf.codification.knime.DinosNodeFactory"/>
                                                               
                                                                           
                	
        	
        <!--
        	
        	NOMINAL / DISCRETE
        	
        	-->
                
                
        
        
        <!-- DISCOVERY -->
                        
        <node category-path="/DINOS Subgroup Discovery/Nominal" description="Analytics" factory-class="cu.edu.cujae.daf.knime.nodes.nominal.DinosNominalSubgroupDiscoveryNodeFactory" id="cu.edu.cujae.daf.knime.nodes.nominal.DinosNominalSubgroupDiscoveryNodeFactory"/>
                		
        
        <!-- PARSER -->
                        
        <node category-path="/DINOS Subgroup Discovery/Nominal" factory-class="cu.edu.cujae.daf.knime.nodes.nominal.DinosNominalParserNodeFactory" id="cu.edu.cujae.daf.knime.nodes.nominal.DinosNominalParserNodeFactory"/>
                        
        
        <!-- EXTRACTOR -->
                            
        <node category-path="/DINOS Subgroup Discovery/Nominal" factory-class="cu.edu.cujae.daf.knime.nodes.nominal.DinosNominalDatasetAsSubgroupExtractorNodeFactory" id="cu.edu.cujae.daf.knime.nodes.nominal.DinosNominalDatasetAsSubgroupExtractorNodeFactory"/>
        	
       		
        <!--
       		
       		NUMERIC
       		
       		-->
                        
        
        
        <!-- DISCOVERY -->
                                
        <node category-path="/DINOS Subgroup Discovery/Numeric" factory-class="cu.edu.cujae.daf.knime.nodes.numeric.DinosNumericSubgroupDiscoveryNodeFactory" id="cu.edu.cujae.daf.knime.nodes.numeric.DinosNumericSubgroupDiscoveryNodeFactory"/>
                
        
        <!-- PARSER -->
                               
        <node category-path="/DINOS Subgroup Discovery/Numeric" factory-class="cu.edu.cujae.daf.knime.nodes.numeric.DinosNumericParserNodeFactory" id="cu.edu.cujae.daf.knime.nodes.numeric.DinosNumericParserNodeFactory"/>
                
        
        <!-- EXTRACTOR -->
                          
        <node category-path="/DINOS Subgroup Discovery/Numeric" factory-class="cu.edu.cujae.daf.knime.nodes.numeric.DinosNumericDatasetAsSubgroupExtractorNodeFactory" id="cu.edu.cujae.daf.knime.nodes.numeric.DinosNumericDatasetAsSubgroupExtractorNodeFactory"/>
                          
        
                	
        	
        <!--
        	
        	SURVIVAl
        	
        	-->
                        
        
        
        <!-- DISCOVERY -->
                        
        <node category-path="/DINOS Subgroup Discovery/Survival" factory-class="cu.edu.cujae.daf.knime.nodes.survival.DinosSurvivalSubgroupDiscoveryNodeFactory" id="cu.edu.cujae.daf.knime.nodes.survival.DinosSurvivalSubgroupDiscoveryNodeFactory"/>
        
        
        <!-- PARSER -->
                
        <node category-path="/DINOS Subgroup Discovery/Survival" factory-class="cu.edu.cujae.daf.knime.nodes.survival.DinosSurvivalParserNodeFactory" id="cu.edu.cujae.daf.knime.nodes.survival.DinosSurvivalParserNodeFactory"/>        
        
        
        <!-- EXTRACTOR -->
                
        <node category-path="/DINOS Subgroup Discovery/Survival" factory-class="cu.edu.cujae.daf.knime.nodes.survival.DinosSurvivalDatasetAsSubgroupExtractorNodeFactory" id="cu.edu.cujae.daf.knime.nodes.survival.DinosSurvivalDatasetAsSubgroupExtractorNodeFactory"/>
                    
       
    </extension>
           

</plugin>
